# ============================================================
# WildfiresAI — Environment Variables (EXAMPLE)
# ------------------------------------------------------------
# This file is a TEMPLATE.
# Copy it to `.env` locally and fill in your real credentials.
#
# cp .env.example .env
#
# Never commit the `.env` file to GitHub.
# ============================================================


# ============================================================
# Core LLM / Multi-Agent Orchestration
# ============================================================

# OpenAI API key used by the reasoning agents
OPENAI_API_KEY=

# Default model used by the agents
LLM_MODEL=gpt-5.1

# Sampling temperature for reasoning agents
LLM_TEMPERATURE=0.2


# ============================================================
# Materials Science Data Sources
# ============================================================

# Materials Project API (used by AgentMaterialsRetriever)
MP_API_KEY=


# ============================================================
# Optional Earth / Fire Data Sources
# (not required for the current materials pipeline,
# but kept for future wildfire environment extensions)
# ============================================================

# NASA FIRMS (active fire detection)
NASA_FIRMS_TOKEN=

# NASA Earthdata credentials
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=

# Topography / elevation API
OPENTOPO_API_KEY=

# Weather / climate data
ECMWF_API_KEY=
NOAA_TOKEN=


# ============================================================
# European / US Fire Monitoring Services (Optional)
# ============================================================

# European Forest Fire Information System
EFFIS_WFS_URL=
EFFIS_WMS_URL=
EFFIS_WCS_URL=

# US National Interagency Fire Center
NIFC_FEATURESERVER_URL=


# ============================================================
# Project Runtime Configuration
# ============================================================

# Root folder for the project
PROJECT_FOLDER=WildfiresAI

# Plot directories used by the pipeline
PLOTS_DIR=plots
PLOTS_V2_DIR=plots_v2


# ============================================================
# Default Demo Parameters
# ============================================================

# Default geographic region used in examples
DEFAULT_REGION_ID=ES-ANDALUCIA

# Default time window (days) for environmental queries
DEFAULT_TIME_WINDOW_DAYS=7


# ============================================================
# Runtime Environment
# ============================================================

# dev | test | production
ENVIRONMENT=dev





